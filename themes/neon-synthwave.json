  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#996699",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#ff0080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#ff80ff"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#ffff80"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#ff40a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#ff80ff"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "storage.type"],
      "settings": {
        "foreground": "#ff0080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.class", "support.class"],
      "settings": {
        "foreground": "#ff40a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.interface"],
      "settings": {
        "foreground": "#ff80ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.enum"],
      "settings": {
        "foreground": "#ffff80",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#ff0080"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#ff80ff"
      }
    },
    {
      "scope": ["meta.brace", "punctuation.section"],
      "settings": {
        "foreground": "#ff0080"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ff40a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#ff80ff"
      }
    }
  ]
}
