  "tokenColors": [
    {
      "name": "Lab Notes (Comments)",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#4d4d80",
        "fontStyle": "italic"
      }
    },
    {
      "name": "DNA Base A (Keywords)",
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": {
        "foreground": "#ff00ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "DNA Base T (Strings/Sequences)",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "DNA Base G (Numbers/Concentrations)",
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "#00ff99"
      }
    },
    {
      "name": "DNA Base C (Functions/Enzymes)",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#bf00ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Gene Variables",
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#b3d9ff"
      }
    },
    {
      "name": "Protein Types",
      "scope": ["entity.name.type", "support.type", "storage.type"],
      "settings": {
        "foreground": "#00ffff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Molecular Classes",
      "scope": ["entity.name.class", "support.class"],
      "settings": {
        "foreground": "#bf00ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interfaces/Membranes",
      "scope": ["entity.name.interface"],
      "settings": {
        "foreground": "#70a1ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Enumerations/Sequences",
      "scope": ["entity.name.enum"],
      "settings": {
        "foreground": "#00ff99",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants/Molecular Weights",
      "scope": ["constant", "constant.other"],
      "settings": {
        "foreground": "#ff00ff"
      }
    },
    {
      "name": "Operators/Bonds",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Punctuation/Structure",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#8080b0"
      }
    },
    {
      "name": "Brackets/Molecular Bonds",
      "scope": ["meta.brace", "punctuation.section"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "HTML/XML Tags",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#bf00ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Attributes/Properties",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "String Values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Sections/Domains",
      "scope": ["entity.name.section"],
      "settings": {
        "foreground": "#70a1ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Support Constants",
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#ff00ff"
      }
    },
    {
      "name": "Storage/Memory",
      "scope": ["storage"],
      "settings": {
        "foreground": "#bf00ff"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#bf00ff"
      }
    },
    {
      "name": "Invalid/Mutations",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff0040",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Deprecated/Old Sequences",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#4d4d80",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Built-in Functions",
      "scope": ["support.function.builtin"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Library Functions",
      "scope": ["support.function.library"],
      "settings": {
        "foreground": "#ff00ff"
      }
    },
    {
      "name": "Namespaces/Organisms",
      "scope": ["entity.name.namespace"],
      "settings": {
        "foreground": "#bf00ff"
      }
    },
    {
      "name": "Modules/Pathways",
      "scope": ["entity.name.module"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Decorators/Annotations",
      "scope": ["entity.name.decorator", "meta.decorator"],
      "settings": {
        "foreground": "#ff00ff"
      }
    },
    {
      "name": "Macros/Primers",
      "scope": ["entity.name.macro"],
      "settings": {
        "foreground": "#00ffff"
      }
    },
    {
      "name": "Labels/Markers",
      "scope": ["entity.name.label"],
      "settings": {
        "foreground": "#00ffff"
      }
    }
  ]
}
