{
  "name": "Electric Blue",
  "type": "dark",
  "colors": {
    "editor.background": "#0a0f1a",
    "editor.foreground": "#e0f0ff",
    "editor.selectionBackground": "#0080ff40",
    "editor.selectionHighlightBackground": "#0080ff20",
    "editor.lineHighlightBackground": "#1a2040",
    "editor.findMatchBackground": "#0080ff60",
    "editor.findMatchHighlightBackground": "#0080ff30",
    "editorCursor.foreground": "#00bfff",
    "editorWhitespace.foreground": "#334080",
    "editorIndentGuide.background": "#334080",
    "editorIndentGuide.activeBackground": "#4080a0",
    "editorLineNumber.foreground": "#4080a0",
    "editorLineNumber.activeForeground": "#00bfff",

    "sideBar.background": "#0f1520",
    "sideBar.foreground": "#c0d0ff",
    "sideBar.border": "#334080",
    "sideBarTitle.foreground": "#0080ff",
    "sideBarSectionHeader.background": "#1a2540",
    "sideBarSectionHeader.foreground": "#00bfff",

    "activityBar.background": "#050a10",
    "activityBar.foreground": "#8090ff",
    "activityBar.inactiveForeground": "#405080",
    "activityBar.border": "#1a2540",
    "activityBarBadge.background": "#0080ff",
    "activityBarBadge.foreground": "#ffffff",

    "statusBar.background": "#0a1520",
    "statusBar.foreground": "#80c0ff",
    "statusBar.border": "#334080",
    "statusBar.debuggingBackground": "#0060c0",
    "statusBar.debuggingForeground": "#ffffff",
    "statusBar.noFolderBackground": "#0a0f1a",

    "titleBar.activeBackground": "#0a0f1a",
    "titleBar.activeForeground": "#e0f0ff",
    "titleBar.inactiveBackground": "#050a10",
    "titleBar.inactiveForeground": "#8090ff",
    "titleBar.border": "#1a2540",

    "menu.background": "#1a2540",
    "menu.foreground": "#e0f0ff",
    "menu.selectionBackground": "#0080ff40",
    "menu.selectionForeground": "#ffffff",
    "menu.separatorBackground": "#334080",

    "menubar.selectionBackground": "#0080ff40",
    "menubar.selectionForeground": "#ffffff",

    "button.background": "#0080ff",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#40a0ff",

    "input.background": "#1a2540",
    "input.foreground": "#e0f0ff",
    "input.border": "#334080",
    "input.placeholderForeground": "#4080a0",

    "dropdown.background": "#1a2540",
    "dropdown.foreground": "#e0f0ff",
    "dropdown.border": "#334080",

    "list.activeSelectionBackground": "#0080ff40",
    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#334080",
    "list.inactiveSelectionForeground": "#e0f0ff",
    "list.hoverBackground": "#1a2540",
    "list.hoverForeground": "#ffffff",

    "tree.indentGuidesStroke": "#334080",

    "panel.background": "#0f1520",
    "panel.border": "#334080",
    "panelTitle.activeBorder": "#0080ff",
    "panelTitle.activeForeground": "#0080ff",
    "panelTitle.inactiveForeground": "#8090ff",

    "terminal.background": "#0a0f1a",
    "terminal.foreground": "#e0f0ff",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#ff4080",
    "terminal.ansiGreen": "#40ff80",
    "terminal.ansiYellow": "#ffff40",
    "terminal.ansiBlue": "#0080ff",
    "terminal.ansiMagenta": "#8040ff",
    "terminal.ansiCyan": "#00bfff",
    "terminal.ansiWhite": "#ffffff",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightRed": "#ff6080",
    "terminal.ansiBrightGreen": "#60ff80",
    "terminal.ansiBrightYellow": "#ffff60",
    "terminal.ansiBrightBlue": "#4080ff",
    "terminal.ansiBrightMagenta": "#a060ff",
    "terminal.ansiBrightCyan": "#40dfff",
    "terminal.ansiBrightWhite": "#ffffff",

    "tab.activeBackground": "#1a2540",
    "tab.activeForeground": "#0080ff",
    "tab.activeBorder": "#0080ff",
    "tab.inactiveBackground": "#0f1520",
    "tab.inactiveForeground": "#8090ff",
    "tab.border": "#334080",

    "editorGroupHeader.tabsBackground": "#0f1520",
    "editorGroupHeader.tabsBorder": "#334080",

    "focusBorder": "#0080ff",
    "foreground": "#e0f0ff",
    "selection.background": "#0080ff40",
    "errorForeground": "#ff4040",
    "descriptionForeground": "#c0d0ff",
    "icon.foreground": "#8090ff"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#4080a0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#0080ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#40c0ff"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#80e0ff"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#00a0ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#c0e0ff"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "storage.type"],
      "settings": {
        "foreground": "#0060c0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.class", "support.class"],
      "settings": {
        "foreground": "#0040a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.interface"],
      "settings": {
        "foreground": "#4080ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.enum"],
      "settings": {
        "foreground": "#80a0ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#60c0ff"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#a0c0e0"
      }
    },
    {
      "scope": ["meta.brace", "punctuation.section"],
      "settings": {
        "foreground": "#20a0ff"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#0070e0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#40b0ff"
      }
    },
    {
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": {
        "foreground": "#80d0ff"
      }
    },
    {
      "scope": ["entity.name.section"],
      "settings": {
        "foreground": "#0090ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#60d0ff"
      }
    },
    {
      "scope": ["storage"],
      "settings": {
        "foreground": "#20b0ff"
      }
    }
  ]
}
